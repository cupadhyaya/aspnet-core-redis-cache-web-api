## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bin/
obj/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# JetBrains Rider
*.sln.iml

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
*.snupkg
packages/
!packages/build/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Publish output
publish/

# Azure
PublishProfiles/

# Coverage files
coverage/
*.coverage
*.coveragexml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# DotNet CLI tools
.dotnet/

# Local secrets
secrets.json
appsettings.Development.json

# Node modules (if frontend exists)
node_modules/

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*

# Temporary files
*.tmp
*.temp